{
  "manifest_version": 3,
  "name": "Currency Translator Pro",
  "version": "1.3.0",
  "description": "Automatically converts currencies and translates text across 15+ languages with multiple fallback APIs for maximum reliability.",
  "permissions": ["storage", "scripting", "activeTab", "alarms"],
  "host_permissions": [
    "https://api.exchangerate.host/*",
    "https://api.exchangerate-api.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://libretranslate.de/*",
    "https://api.mymemory.translated.net/*",
    "https://translate.googleapis.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon_16x16.png",
      "48": "icon_48x48.png",
      "128": "icon_128x128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Currency Translator Pro"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon_16x16.png",
    "48": "icon_48x48.png",
    "128": "icon_128x128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icon_16x16.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
