{
  "manifest_version": 3,
  "name": "Currency Converter Pro",
  "version": "1.0.0",
  "author": "PMFB",
  "description": "Automatically converts detected prices into your preferred currency with bounded caching and safe fallbacks.",
  "homepage_url": "https://github.com/pmfb/currency-lang-translator",
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": [
    "https://api.frankfurter.app/*",
    "https://api.exchangerate.host/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon_16x16.png",
      "48": "icon_48x48.png",
      "128": "icon_128x128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Open Currency Converter"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": ["*://*.google.com/search*", "*://*.bing.com/search*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon_48x48.png",
    "128": "icon_128x128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
