{
  "manifest_version": 3,
  "name": "Currency Translator Pro",
  "version": "1.3.0",
  "author": "PMFB",
  "description": "Automatically converts currencies and translates text across 15+ languages with multiple fallback APIs for maximum reliability.",
  "homepage_url": "https://github.com/pmfb/currency-lang-translator",
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": [
    "https://api.exchangerate.host/*",
    "https://api.exchangerate-api.com/*",
    "https://cdn.jsdelivr.net/*",
    "https://libretranslate.de/*",
    "https://api.mymemory.translated.net/*",
    "https://translate.googleapis.com/*"
  ],
  "action": {
    "default_icon": {
      "16": "icon_16x16.png",
      "48": "icon_48x48.png",
      "128": "icon_128x128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Open Currency Translator"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": ["*://*.google.com/search*", "*://*.bing.com/search*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon_48x48.png",
    "128": "icon_128x128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
