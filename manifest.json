{
  "manifest_version": 3,
  "name": "Currency Translator",
  "version": "1.0",
  "description": "Detects prices and converts them to your preferred currency.",
  "permissions": ["storage", "scripting", "activeTab"],
  "action": {
    "default_icon": {
      "16": "icon_16x16.png",
      "48": "icon_48x48.png",
      "128": "icon_128x128.png"
    },
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon_16x16.png",
    "48": "icon_48x48.png",
    "128": "icon_128x128.png"
  }
}
